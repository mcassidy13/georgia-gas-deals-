# Copy this file to .env.local and fill in your values.

# Your live site URL — used for SEO metadata, sitemap, and Open Graph
# Use your Vercel URL until you have a custom domain
NEXT_PUBLIC_SITE_URL=https://georgia-gas-deals.vercel.app

# Supabase credentials — find these at: Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-only, bypasses RLS. Find at: Supabase → Settings → API → service_role
# NEVER expose this to the browser or commit it to version control.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
